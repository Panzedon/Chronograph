/* 104 */	_dummit,		/* CAN1 or'ed message buffer 0-15 */
/* 105 */	_dummit,		/* CAN1 reserved ext 16-31 */
/* 106 */	_dummit,		/* CAN1 reserved ext 32-47 */
/* 107 */	_dummit,		/* CAN1 reserved ext 48-63 */
/* 108 */	_dummit,		/* CAN2 or'ed bus off/warnings */
/* 109 */	_dummit,		/* CAN2 error */
/* 110 */	_dummit,		/* CAN2 wake up */
/* 111 */	_dummit,		/* CAN2 or'ed message buffer 0-15 */

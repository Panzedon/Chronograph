/* 93 */	_dummit,		/* reserved */
/* 94 */	_dummit,		/* CAN0 or'ed bus off/warnings */
/* 95 */	_dummit,		/* CAN0 error */
/* 96 */	_dummit,		/* CAN0 wake up */
/* 97 */	_dummit,		/* CAN0 or'ed message buffer 0-15 */
/* 98 */	_dummit,		/* CAN0 reserved ext 16-31 */

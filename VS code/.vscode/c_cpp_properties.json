{
    "configurations": [
        {
            "name": "COSMIC STM8",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/tools/COSMIC/FSE_Compilers/CXSTM8/Hstm8",
                "${workspaceFolder}/tools/COSMIC/FSE_Compilers/CXSTM8/Lib",
                "${workspaceFolder}/tools/COSMIC/stsw-stm8069/STM8S_StdPeriph_Lib/Libraries/STM8S_StdPeriph_Driver/inc"
            ],
            "defines": [
                "__CSMC__",
                "STM8S103",
                "__STDC__",
                "@svlreg="
            ],
            "forcedInclude": [
                "${workspaceFolder}/mocks/iostm8s103.h"
            ],
            "intelliSenseMode": "windows-msvc-x86",
            "cStandard": "c89",
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${workspaceFolder}/tools/COSMIC/FSE_Compilers/CXSTM8/Hstm8"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}